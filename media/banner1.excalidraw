    {
      "id": "inc_ali3L6MT6AV-JNwjM",
      "type": "text",
      "x": 12612.023273628285,
      "y": -10502.57329495059,
      "width": 943.9915771484375,
      "height": 765,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bO7",
      "roundness": null,
      "seed": 872961504,
      "version": 305,
      "versionNonce": 1701176745,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783479560474,
      "link": null,
      "locked": false,
      "text": "    def triples_sum_to_zero(l: list):\n    \"\"\"\n    triples_sum_to_zero takes a list of integers as an input.\n    it returns True if there are three distinct elements in the \n    list that sum to zero, and False otherwise.\n    \n    >>> triples_sum_to_zero([1, 3, 5, 0])\n    False\n    >>> triples_sum_to_zero([1, 3, -2, 1])\n    True\n    >>> triples_sum_to_zero([1, 2, 3, 7])\n    False\n    >>> triples_sum_to_zero([2, 4, -5, 3, 9, 7])\n    True\n    >>> triples_sum_to_zero([1])\n    False\n    \"\"\"",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "9PU4Cffcx-e7SFo6OG6R4",
      "originalText": "    def triples_sum_to_zero(l: list):\n    \"\"\"\n    triples_sum_to_zero takes a list of integers as an input.\n    it returns True if there are three distinct elements in the \n    list that sum to zero, and False otherwise.\n    \n    >>> triples_sum_to_zero([1, 3, 5, 0])\n    False\n    >>> triples_sum_to_zero([1, 3, -2, 1])\n    True\n    >>> triples_sum_to_zero([1, 2, 3, 7])\n    False\n    >>> triples_sum_to_zero([2, 4, -5, 3, 9, 7])\n    True\n    >>> triples_sum_to_zero([1])\n    False\n    \"\"\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dd6h8uYL4xv85C5vAbrJZ",
      "type": "rectangle",
      "x": 13641.106912847283,
      "y": -10539.772747107445,
      "width": 869.4689945686644,
      "height": 586.1487010116616,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f3f0ff",
