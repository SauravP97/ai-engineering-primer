    },
    {
      "id": "tfNF5sFYVTTq5yBVmC6uy",
      "type": "text",
      "x": 13646.106912847283,
      "y": -10471.698396601614,
      "width": 778.9317626953125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bO9",
      "roundness": null,
      "seed": 1070140448,
      "version": 468,
      "versionNonce": 416106633,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783479560474,
      "link": null,
      "locked": false,
      "text": "    def check(candidate):\n        assert candidate([1, 3, 5, 0]) == False\n        assert candidate([1, 3, 5, -1]) == False\n        assert candidate([1, 3, -2, 1]) == True\n        assert candidate([1, 2, 3, 7]) == False\n        assert candidate([1, 2, 5, 7]) == False\n        assert candidate([2, 4, -5, 3, 9, 7]) == True\n        assert candidate([1]) == False\n        assert candidate([1, 3, 5, -100]) == False\n        assert candidate([100, 3, 5, -100]) == False",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "dd6h8uYL4xv85C5vAbrJZ",
      "originalText": "    def check(candidate):\n        assert candidate([1, 3, 5, 0]) == False\n        assert candidate([1, 3, 5, -1]) == False\n        assert candidate([1, 3, -2, 1]) == True\n        assert candidate([1, 2, 3, 7]) == False\n        assert candidate([1, 2, 5, 7]) == False\n        assert candidate([2, 4, -5, 3, 9, 7]) == True\n        assert candidate([1]) == False\n        assert candidate([1, 3, 5, -100]) == False\n        assert candidate([100, 3, 5, -100]) == False",
      "autoResize": true,
      "lineHeight": 1.25
    },
